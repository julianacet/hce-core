COMPOSE_PROJECT_NAME=consultorio

# Base de datos (mismas credenciales que en Linux)
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=hce_provider
DB_PORT=5432

DATABASE_URL=postgresql://your-db-user:your-db-password@consultorio-db:5432/hce_provider?sslmode=disable
JWT_SECRET=your-jwt-secret-base64
PORT=8000

VITE_API_URL=http://localhost:8000
APP_TZ=America/Bogota

DOCKER_API_PORT=8000
DOCKER_VITE_API_URL=http://localhost:8000

# ── Windows: UI en 8090 para evitar conflicto con IIS / puerto 80 ────────────
UI_PORT=8090
DOCKER_ALLOWED_ORIGIN=http://localhost:8090

# ── Windows: impresión vía relay HTTP (hce-print-relay.exe) ──────────────────
PRINTER_TERMICA=POS5890K
PRINTER_MODE=http
PRINTER_HTTP_URL=http://host.docker.internal:8765
